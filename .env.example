# Optional: use Google Maps instead of OpenStreetMap on the Map tab (Maps JavaScript API).
# If unset or invalid, the app uses OpenStreetMap (Leaflet) — no key required.
VITE_GOOGLE_MAPS_API_KEY=

# Backend API base URL (no trailing slash), used in production builds.
# Example: VITE_API_URL=https://your-backend.onrender.com
VITE_API_URL=
